generator client {
  provider = "prisma-client"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id            String        @id @default(cuid())
  title         String
  description   String?
  status        CompanyStatus
  joinedDate    DateTime?
  hasPromotions Boolean       @default(false)
  promotions    Promotion[]
  categoryId    String?
  categoryTitle String?
  countryId     String?
  countryTitle  String?
  avatar        String?
  sold          Int           @default(0)
  income        Decimal       @default(0)

  @@map("companies")
}

enum CompanyStatus {
  active
  notActive
  pending
  suspended
}


model Promotion {
  id          String   @id @default(cuid())
  title       String
  description String
  discount    Float
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  avatar      String?

  @@map("promotions")
}